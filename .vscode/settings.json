{
  // WordPress PHPCS: composer install && composer run lint && composer run format
  "editor.formatOnSave": true,
  "editor.insertSpaces": false,
  "editor.detectIndentation": false,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "[php]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 4,
    "editor.formatOnSave": false
  },
  "[javascript]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 4
  },
  "[css]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 4
  },
  "intelephense.environment.includePaths": [
    "${workspaceFolder}",
    "${workspaceFolder}/.intelephense-stubs"
  ],
  "intelephense.files.exclude": ["**/vendor/**", "**/.git/**"],
  "intelephense.stubs": [
    "superglobals",
    "Core",
    "standard",
    "date",
    "json",
    "openssl",
    "filter",
    "mbstring",
    "pcre",
    "hash",
    "ctype",
    "random"
  ]
}
